# Copy to `.env` for deployment. Replace all secrets.
NODE_ENV=development
PORT=8000
MONGODB_URI=mongodb+srv://user:password@cluster/dbname

# Firebase Admin — service account JSON as single line or path to JSON file
GOOGLE_APPLICATION_CREDENTIALS_JSON=

# Allowed browser origins for CORS (comma-separated). Production must match your SPA URL exactly.
CLIENT_URLS=http://localhost:3000
